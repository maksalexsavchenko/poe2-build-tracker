# Traefik (імена як у static config Traefik на сервері)
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_CERTRESOLVER=le

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# NextAuth
NEXTAUTH_SECRET=change_me_run_openssl_rand_base64_32
NEXTAUTH_URL=https://poe2-build-tracker.online

# GGG OAuth (отримаєш після реєстрації на oauth@grindinggear.com)
GGG_CLIENT_ID=
GGG_CLIENT_SECRET=

# Опційно: окремий Python MCP poe2-mcp (геми/моди) — не змінює Next.js:
# https://github.com/HivemindOverlord/poe2-mcp
# RePoE PoE2 JSON: npm run vendor:game-data → public/data/repoe-poe2/
# Ланцюжок: Content.ggpk → github.com/ggpk-exposed → repoe-fork.github.io/poe2 → vendor
# Опційно збільшити дамп (експортуй перед npm run vendor:game-data):
#   DOWNLOAD_REPOE_SKILLS=1          — skills.min.json (~12 MB)
#   DOWNLOAD_REPOE_STATS_BY_FILE=1  — stats_by_file.min.json (~8 MB)
# Приклад API: /api/game/repoe/mods.min.json , /api/game/repoe/stat_translations/skill_stat_descriptions.min.json
